# Copy to .env and edit as needed. Optional: backend loads these from the environment.

# --- PostgreSQL (research-grade meeting storage). If unset, meetings fall back to JSON files in data/meetings ---
# DATABASE_URL=postgresql://user:password@localhost:5432/prose_meet

# --- Whisper model (faster-whisper / CTranslate2) ---
# Preset (downloaded on first run): tiny, base, small, medium, large-v3, large-v3-turbo
# WHISPER_MODEL=tiny

# Or use a converted fine-tuned model: set to the full path of the CTranslate2 output directory
# Example (Windows): WHISPER_MODEL=C:\models\whisper-ctranslate2
# Example (Mac/Linux): WHISPER_MODEL=/home/me/models/whisper-ctranslate2
# WHISPER_MODEL=

# Force GPU (optional; otherwise auto-detected)
# USE_CUDA=1

# Disable batching if you see transcription errors (optional)
# WHISPER_DISABLE_BATCH=0

# Disable VAD to transcribe the whole file (helps capture very quiet speech; may add noise)
# WHISPER_NO_VAD=1

# --- Speaker estimation ---
# Speaker labels are inferred from pause-aware turn segmentation (no external diarization token required).

# --- Gap 2 domain detection ---
# Default: ssl_zero_shot = frozen self-supervised sentence encoder + prototype zero-shot (no meeting-domain fine-tuning).
# keyword = lexical baseline only (no encoder).
# PROSE_DOMAIN_METHOD=ssl_zero_shot
# PROSE_DOMAIN_METHOD=keyword
# Optional: Hugging Face / sentence-transformers model id (default: sentence-transformers/all-MiniLM-L6-v2)
# PROSE_SSL_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Softmax temperature over cosine similarities (higher = softer probabilities)
# PROSE_SSL_TEMPERATURE=8

# --- CORS (allowed frontend origins). If the UI runs on another host/port, add it here. ---
# Comma-separated list, e.g.: http://localhost:5173,https://app.example.com
# BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
